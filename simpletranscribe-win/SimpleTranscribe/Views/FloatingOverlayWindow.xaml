<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SimpleTranscribe.Views.FloatingOverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="SimpleTranscribeOverlay">

    <Border x:Name="RootBorder"
            Background="#CC1E1E1E"
            CornerRadius="8"
            Padding="12,6"
            HorizontalAlignment="Left"
            VerticalAlignment="Top">
        <StackPanel Orientation="Horizontal" Spacing="8"
                    VerticalAlignment="Center">

            <!-- Recording state: pulsing red dot -->
            <Ellipse x:Name="RecordingDot"
                     Width="10" Height="10"
                     Fill="#FFEF4444"
                     VerticalAlignment="Center"
                     Visibility="Collapsed">
                <Ellipse.Resources>
                    <Storyboard x:Name="PulseStoryboard" RepeatBehavior="Forever">
                        <DoubleAnimation
                            Storyboard.TargetName="RecordingDot"
                            Storyboard.TargetProperty="Opacity"
                            From="1.0" To="0.3"
                            Duration="0:0:0.8"
                            AutoReverse="True" />
                    </Storyboard>
                </Ellipse.Resources>
            </Ellipse>

            <!-- Transcribing state: spinning ring -->
            <ProgressRing x:Name="TranscribingRing"
                          Width="14" Height="14"
                          IsActive="False"
                          Visibility="Collapsed"
                          Foreground="White" />

            <!-- Done state: green checkmark -->
            <FontIcon x:Name="DoneIcon"
                      Glyph="&#xE73E;"
                      FontSize="14"
                      Foreground="#FF22C55E"
                      Visibility="Collapsed" />

            <!-- Error state: red X -->
            <FontIcon x:Name="ErrorIcon"
                      Glyph="&#xE711;"
                      FontSize="14"
                      Foreground="#FFEF4444"
                      Visibility="Collapsed" />

            <!-- Status text -->
            <TextBlock x:Name="StatusText"
                       Text=""
                       Foreground="White"
                       FontSize="13"
                       VerticalAlignment="Center" />
        </StackPanel>
    </Border>
</Window>

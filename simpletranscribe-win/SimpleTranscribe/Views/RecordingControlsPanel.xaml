<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SimpleTranscribe.Views.RecordingControlsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="16" Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Transcribe / Stop button -->
        <Button x:Name="RecordButton"
                Grid.Column="0"
                Click="OnToggleRecording"
                IsEnabled="False"
                Style="{StaticResource AccentButtonStyle}">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon x:Name="RecordIcon" Glyph="&#xE720;" FontSize="16" />
                <TextBlock x:Name="RecordText" Text="Transcribe" />
            </StackPanel>
        </Button>

        <!-- Hotkey badge -->
        <Border Grid.Column="1"
                Margin="8,0,0,0"
                Padding="6,2"
                CornerRadius="4"
                Background="{ThemeResource ControlFillColorDisabledBrush}">
            <TextBlock Text="Ctrl+Space"
                       FontSize="11"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       ToolTipService.ToolTip="Hold Ctrl+Space to start recording, release to stop and transcribe" />
        </Border>

        <!-- Processing indicator -->
        <StackPanel x:Name="ProcessingPanel"
                    Grid.Column="2"
                    Orientation="Horizontal"
                    Margin="12,0,0,0"
                    Visibility="Collapsed">
            <ProgressRing IsActive="True" Width="16" Height="16" />
            <TextBlock Text="Processing..."
                       Margin="6,0,0,0"
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- Transcription started indicator -->
        <StackPanel x:Name="TranscriptionStartedPanel"
                    Grid.Column="3"
                    Orientation="Horizontal"
                    Margin="12,0,0,0"
                    Visibility="Collapsed">
            <FontIcon Glyph="&#xEC48;" FontSize="14" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
            <TextBlock Text="Transcription started"
                       Margin="6,0,0,0"
                       FontSize="12"
                       Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- Models button -->
        <Button Grid.Column="5"
                Click="OnShowModelManager">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon Glyph="&#xE713;" FontSize="14" />
                <TextBlock Text="Models" />
            </StackPanel>
        </Button>
    </Grid>
</UserControl>

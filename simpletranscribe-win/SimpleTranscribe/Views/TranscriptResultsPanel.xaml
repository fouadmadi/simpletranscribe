<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SimpleTranscribe.Views.TranscriptResultsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <TextBox x:Name="TranscriptTextBox"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 IsSpellCheckEnabled="False"
                 Padding="16"
                 FontSize="14"
                 MinHeight="200"
                 PlaceholderText="Transcribed text will appear here..."
                 VerticalAlignment="Stretch"
                 HorizontalAlignment="Stretch"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 TextChanged="OnTextChanged" />

        <!-- Copy button overlay (bottom-right) -->
        <Button x:Name="CopyButton"
                Click="OnCopy"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Margin="16"
                ToolTipService.ToolTip="Copy to Clipboard"
                Padding="8">
            <FontIcon Glyph="&#xE8C8;" FontSize="16" />
        </Button>

        <!-- Copied tooltip -->
        <TeachingTip x:Name="CopiedTip"
                     Target="{x:Bind CopyButton}"
                     Title="Copied!"
                     IsLightDismissEnabled="True"
                     PreferredPlacement="Top" />
    </Grid>
</UserControl>

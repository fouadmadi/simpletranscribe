<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SimpleTranscribe.Views.TranscriptResultsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="*,Auto">

        <TextBox Grid.Row="0"
                 x:Name="TranscriptTextBox"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 IsSpellCheckEnabled="False"
                 Padding="16"
                 FontSize="14"
                 MinHeight="200"
                 PlaceholderText="Transcribed text will appear here..."
                 VerticalAlignment="Stretch"
                 HorizontalAlignment="Stretch"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 TextChanged="OnTextChanged" />

        <!-- Live preview strip (shown while recording if streaming is enabled) -->
        <Border Grid.Row="1"
                x:Name="LivePreviewBorder"
                Background="{ThemeResource ControlAltFillColorTertiaryBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,8"
                Visibility="Collapsed">
            <TextBlock x:Name="LivePreviewText"
                       TextWrapping="Wrap"
                       FontStyle="Italic"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="13" />
        </Border>

        <!-- Copy button overlay (bottom-right of row 0) -->
        <Button x:Name="CopyButton"
                Grid.Row="0"
                Click="OnCopy"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Margin="16"
                ToolTipService.ToolTip="Copy to Clipboard"
                Padding="8">
            <FontIcon Glyph="&#xE8C8;" FontSize="16" />
        </Button>

        <!-- Copied tooltip -->
        <TeachingTip x:Name="CopiedTip"
                     Grid.Row="0"
                     Target="{x:Bind CopyButton}"
                     Title="Copied!"
                     IsLightDismissEnabled="True"
                     PreferredPlacement="Top" />
    </Grid>
</UserControl>

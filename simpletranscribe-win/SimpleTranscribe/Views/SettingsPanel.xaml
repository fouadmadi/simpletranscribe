<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SimpleTranscribe.Views.SettingsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
        <StackPanel Orientation="Horizontal" Spacing="20">
            <!-- Microphone picker -->
            <StackPanel Spacing="4">
                <TextBlock Text="Microphone" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <ComboBox x:Name="MicrophoneComboBox"
                          Width="250"
                          SelectionChanged="OnMicrophoneChanged"
                          PlaceholderText="Detecting…" />
                <CheckBox x:Name="UseSystemDefaultCheckBox"
                          Content="Use system default"
                          FontSize="12"
                          Checked="OnUseSystemDefaultChanged"
                          Unchecked="OnUseSystemDefaultChanged" />
                <TextBlock x:Name="DeviceSwitchMessageText"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="Collapsed" />
            </StackPanel>

            <!-- Model picker -->
            <StackPanel Spacing="4">
                <TextBlock Text="Model" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <ComboBox x:Name="ModelComboBox"
                          Width="200"
                          SelectionChanged="OnModelChanged"
                          PlaceholderText="No models downloaded" />
            </StackPanel>

            <!-- Language picker -->
            <StackPanel Spacing="4">
                <TextBlock Text="Language" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <ComboBox x:Name="LanguageComboBox"
                          Width="170"
                          SelectionChanged="OnLanguageChanged"
                          PlaceholderText="Select language" />
            </StackPanel>
            <!-- Hotkey recorder -->
            <StackPanel Spacing="4">
                <TextBlock Text="Hotkey" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBox x:Name="HotKeyBox"
                         Width="130"
                         IsReadOnly="True"
                         PlaceholderText="Click to record"
                         GotFocus="HotKeyBox_GotFocus"
                         LostFocus="HotKeyBox_LostFocus"
                         KeyDown="HotKeyBox_KeyDown"
                         ToolTipService.ToolTip="Click then press your desired key combo" />
                <TextBlock x:Name="HotKeyConflictText"
                           Text="⚠ May conflict with system shortcuts"
                           FontSize="11"
                           Foreground="Orange"
                           Visibility="Collapsed" />
                <HyperlinkButton x:Name="HotKeyResetButton"
                                 Content="Reset to default"
                                 FontSize="11"
                                 Padding="0"
                                 Click="HotKeyReset_Click" />
            </StackPanel>

            <!-- Live preview toggle -->
            <StackPanel Spacing="4" VerticalAlignment="Center">
                <CheckBox x:Name="StreamingCheckBox"
                          Content="Live preview"
                          FontSize="12"
                          ToolTipService.ToolTip="Show partial transcription while recording (Whisper only)"
                          Checked="OnStreamingChanged"
                          Unchecked="OnStreamingChanged" />
            </StackPanel>

            <!-- Text processing toggles -->
            <StackPanel Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="Text Processing" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <CheckBox x:Name="CapitaliseCheckBox"
                          Content="Capitalise sentences"
                          FontSize="12"
                          Checked="OnCapitaliseChanged"
                          Unchecked="OnCapitaliseChanged" />
                <CheckBox x:Name="FillersCheckBox"
                          Content="Remove filler words"
                          FontSize="12"
                          Checked="OnFillersChanged"
                          Unchecked="OnFillersChanged" />
                <CheckBox x:Name="NumbersCheckBox"
                          Content="Number formatting"
                          FontSize="12"
                          Checked="OnNumbersChanged"
                          Unchecked="OnNumbersChanged" />
                <CheckBox x:Name="AutoClearCheckBox"
                          Content="Auto-clear after paste"
                          FontSize="12"
                          ToolTipService.ToolTip="Clears transcript after each auto-paste"
                          Checked="OnAutoClearChanged"
                          Unchecked="OnAutoClearChanged" />
            </StackPanel>

            <!-- Font size control -->
            <StackPanel Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="Text Size" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Slider x:Name="FontSizeSlider"
                            Minimum="11" Maximum="28" StepFrequency="1"
                            Width="100"
                            ValueChanged="OnFontSizeChanged" />
                    <TextBlock x:Name="FontSizeLabel"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>

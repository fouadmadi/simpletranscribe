<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SimpleTranscribe.Views.ModelDownloadPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="16" RowDefinitions="Auto,Auto,*">
        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Transcription Models" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Select or download a model to get started"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
            <Button Grid.Column="1" Click="OnClose" ToolTipService.ToolTip="Close">
                <FontIcon Glyph="&#xE711;" />
            </Button>
        </Grid>

        <!-- Storage info -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <FontIcon Glyph="&#xEDA2;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock x:Name="StorageText"
                       Text="Storage Used: 0 MB"
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Model list -->
        <ScrollViewer Grid.Row="2">
            <StackPanel x:Name="ModelList" Spacing="8" />
        </ScrollViewer>
    </Grid>
</UserControl>

<Window
    x:Class="SimpleTranscribe.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:SimpleTranscribe.Views"
    Title="SimpleTranscribe">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto">
        <!-- Recording controls -->
        <MenuBar Grid.Row="0">
            <MenuBarItem Title="Help">
                <MenuFlyoutItem Text="About" Click="OnAboutMenuClicked"/>
            </MenuBarItem>
        </MenuBar>
        <views:RecordingControlsPanel x:Name="RecordingControls" Grid.Row="0" />

        <Border Grid.Row="1" Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Settings (mic, model, language pickers) -->
        <views:SettingsPanel x:Name="Settings" Grid.Row="2" />

        <Border Grid.Row="3" Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Transcript area: results + optional history side panel -->
        <Grid Grid.Row="4" RowDefinitions="Auto,*" ColumnDefinitions="*,Auto">
            <InfoBar x:Name="TimeLimitWarningBar"
                     Grid.Row="0"
                     Grid.ColumnSpan="2"
                     IsOpen="False"
                     Severity="Warning"
                     Title="Approaching recording limit"
                     Message="Less than 2 minutes of recording time remaining."
                     IsClosable="False"
                     Margin="16,16,16,0" />

            <views:TranscriptResultsPanel x:Name="TranscriptResults" Grid.Row="1" Grid.Column="0" />

            <Border Grid.Row="1" Grid.Column="1" x:Name="HistoryBorder"
                    Width="280"
                    Visibility="Collapsed"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1,0,0,0">
                <views:TranscriptHistoryPanel x:Name="HistoryPanel" />
            </Border>
        </Grid>

        <!-- Status bar: word count, char count, duration -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    Spacing="16"
                    Padding="16,4"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <TextBlock x:Name="WordCountText" FontSize="11"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="Collapsed" />
            <TextBlock x:Name="CharCountText" FontSize="11"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="Collapsed" />
            <TextBlock x:Name="DurationText" FontSize="11"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="Collapsed" />
            <TextBlock x:Name="RecordingElapsedText" FontSize="11"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="Collapsed" />
        </StackPanel>

        <!-- Model status banner -->
        <Border x:Name="ModelStatusBanner" Grid.Row="6" Visibility="Collapsed"
                Padding="16" Background="{ThemeResource SystemFillColorCautionBackgroundBrush}">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <FontIcon x:Name="BannerIcon" Glyph="&#xE946;" FontSize="16"
                          Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                <TextBlock x:Name="BannerText" Grid.Column="1" Margin="8,0" FontSize="12"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Button x:Name="BannerButton" Grid.Column="2" FontSize="12"
                        Style="{StaticResource AccentButtonStyle}"
                        Visibility="Collapsed" />
            </Grid>
        </Border>

        <!-- Error banner -->
        <Border x:Name="ErrorBanner" Grid.Row="7" Visibility="Collapsed"
                Padding="16">
            <TextBlock x:Name="ErrorText" FontSize="12" Foreground="Red" TextWrapping="Wrap" />
        </Border>

        <!-- Model download overlay -->
        <Border x:Name="ModelOverlay" Grid.Row="0" Grid.RowSpan="8" Visibility="Collapsed"
                Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}">
            <views:ModelDownloadPage x:Name="ModelDownloadPanel" />
        </Border>
    </Grid>
</Window>
